# =============================================================================
# PaisaRupay — Environment Variables Reference
# =============================================================================
#
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For production (Vercel / server), set these in the deployment dashboard.
# ⚠️  NEVER commit .env.local or .env.prod — they contain real secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# Resend — Transactional Email
# -----------------------------------------------------------------------------
# Used to send notification emails to the team and confirmation emails to users.
# Get your API key at: https://resend.com/api-keys
# Required: YES
RESEND_API_KEY=""


# -----------------------------------------------------------------------------
# Google Sheets Webhook — Form Data Logging
# -----------------------------------------------------------------------------
# The Google Apps Script deployment URL that receives form submissions
# and writes them to your Google Sheet.
# How to get it: Extensions → Apps Script → Deploy → New deployment → Web app
# Required: YES
WEBSITE_CONTACT_US_SHEET_LINK=""

# The deployment ID portion of the webhook URL (used for reference / auditing).
# Required: NO (informational only — not used in code at runtime)
WEBSITE_CONTACT_US_SHEET_DEPLOYEMENT_ID=""


# -----------------------------------------------------------------------------
# Google Analytics 4
# -----------------------------------------------------------------------------
# Your GA4 Measurement ID. Found in: GA4 → Admin → Data Streams → your stream.
# Format: G-XXXXXXXXXX
# Required: NO (analytics will be disabled if missing)
GOOGLE_ANALYTICS_ID=""


# -----------------------------------------------------------------------------
# Microsoft Clarity
# -----------------------------------------------------------------------------
# Your Clarity Project ID. Found in: clarity.microsoft.com → your project → Settings.
# Required: NO (Clarity will be disabled if missing)
CLARITY_ID=""


# -----------------------------------------------------------------------------
# Supabase — Primary Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Used to persist all form submissions and referral code data.
# Get these from: Supabase Dashboard → Project → Settings → Database → Connection string
#
# DATABASE_URL  → Use the "Transaction" mode pooler (port 6543).
#                 Add ?pgbouncer=true at the end. Used by Prisma at runtime.
# DIRECT_URL    → Use the "Direct connection" (port 5432).
#                 Used only by `prisma migrate dev` — bypasses pgbouncer for DDL.
#
# Required: YES (Supabase writes will fail silently without these, but forms still work)
DATABASE_URL=""
DIRECT_URL=""


# -----------------------------------------------------------------------------
# Referral System — HMAC Secret
# -----------------------------------------------------------------------------
# Secret key used to generate deterministic referral codes via HMAC-SHA256.
# Same name + phone + email will always produce the same 8-character code.
#
# ⚠️  IMPORTANT:
#   - Generate a strong random string (32+ characters recommended).
#   - If this value changes, ALL existing referral codes become invalid.
#   - Keep this secret — anyone with this key can forge referral codes.
#
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required: YES (referral code generation will throw an error without this)
REFERRAL_HMAC_SECRET=""


# -----------------------------------------------------------------------------
# Legacy / Deprecated
# -----------------------------------------------------------------------------
# BACKEND_URL was previously used by Server Actions to make an internal HTTP
# round-trip to /api/send_mail. This pattern has been removed — Server Actions
# now call email functions directly. This variable is no longer needed.
# BACKEND_URL=""
